# Copy this file to .env and fill in values as needed.

# prompt-optimizer — at least one of the following is required.
# Groq is the default primary provider; NVIDIA NIM is the fallback.
# Sign up at https://console.groq.com (free tier).
GROQ_API_KEY=

# Sign up at https://build.nvidia.com (free tier). NVIDIA_API_KEY is accepted
# as an alias.
NVIDIA_NIM_API_KEY=
